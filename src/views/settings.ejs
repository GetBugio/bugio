<%- include('partials/header') %>

<div class="settings-page">
  <div class="page-header">
    <h1><%= t('settings.title') %></h1>
  </div>

  <!-- Password -->
  <div class="settings-card card">
    <h2 class="settings-card-title"><%= t('settings.changePassword') %></h2>
    <form id="change-password-form" data-form="change-password">
      <div class="form-group">
        <label for="currentPassword"><%= t('settings.currentPassword') %></label>
        <input type="password" id="currentPassword" name="currentPassword" required>
      </div>
      <div class="form-group">
        <label for="newPassword"><%= t('settings.newPassword') %></label>
        <input type="password" id="newPassword" name="newPassword" required minlength="4">
      </div>
      <div class="form-group">
        <label for="confirmNewPassword"><%= t('settings.confirmNewPassword') %></label>
        <input type="password" id="confirmNewPassword" name="confirmNewPassword" required>
      </div>
      <button type="submit" class="btn btn-primary"><%= t('settings.changePasswordBtn') %></button>
    </form>
  </div>

  <!-- Email -->
  <div class="settings-card card">
    <h2 class="settings-card-title"><%= t('settings.changeEmail') %></h2>
    <p class="settings-current-value"><%= t('settings.currentEmail') %> <strong><%= user.email %></strong></p>
    <form id="change-email-form" data-form="change-email">
      <div class="form-group">
        <label for="emailPassword"><%= t('settings.passwordLabel') %></label>
        <input type="password" id="emailPassword" name="password" required>
      </div>
      <div class="form-group">
        <label for="newEmail"><%= t('settings.newEmail') %></label>
        <input type="email" id="newEmail" name="newEmail" required>
      </div>
      <button type="submit" class="btn btn-primary"><%= t('settings.changeEmailBtn') %></button>
    </form>
  </div>

  <% if (user.role === 'admin') { %>
  <!-- System Settings (Admin) -->
  <div class="settings-card card">
    <h2 class="settings-card-title"><%= t('settings.system') %></h2>
    <form id="system-settings-form" data-form="system-settings">
      <div class="form-group">
        <label for="systemName"><%= t('settings.systemName') %></label>
        <input type="text" id="systemName" name="system_name" value="<%= allSettings.system_name %>" placeholder="<%= t('settings.systemNamePlaceholder') %>">
      </div>
      <div class="form-group">
        <label for="logoPath"><%= t('settings.logoUrl') %></label>
        <input type="text" id="logoPath" name="logo_path" value="<%= allSettings.logo_path %>" placeholder="<%= t('settings.logoPlaceholder') %>">
      </div>
      <button type="submit" class="btn btn-primary"><%= t('common.save') %></button>
    </form>
  </div>

  <!-- Theme Colors (Admin) -->
  <div class="settings-card card">
    <h2 class="settings-card-title"><%= t('settings.themeColors') %></h2>
    <form id="theme-colors-form" data-form="theme-colors">
      <div class="color-grid">
        <div class="color-item">
          <label for="primaryColor"><%= t('settings.primary') %></label>
          <div class="color-input-row">
            <input type="color" id="primaryColor" name="primary_color" value="<%= allSettings.primary_color %>">
            <span class="color-hex"><%= allSettings.primary_color %></span>
          </div>
        </div>
        <div class="color-item">
          <label for="secondaryColor"><%= t('settings.secondary') %></label>
          <div class="color-input-row">
            <input type="color" id="secondaryColor" name="secondary_color" value="<%= allSettings.secondary_color %>">
            <span class="color-hex"><%= allSettings.secondary_color %></span>
          </div>
        </div>
        <div class="color-item">
          <label for="successColor"><%= t('settings.success') %></label>
          <div class="color-input-row">
            <input type="color" id="successColor" name="success_color" value="<%= allSettings.success_color %>">
            <span class="color-hex"><%= allSettings.success_color %></span>
          </div>
        </div>
        <div class="color-item">
          <label for="warningColor"><%= t('settings.warning') %></label>
          <div class="color-input-row">
            <input type="color" id="warningColor" name="warning_color" value="<%= allSettings.warning_color %>">
            <span class="color-hex"><%= allSettings.warning_color %></span>
          </div>
        </div>
        <div class="color-item">
          <label for="errorColor"><%= t('settings.error') %></label>
          <div class="color-input-row">
            <input type="color" id="errorColor" name="error_color" value="<%= allSettings.error_color %>">
            <span class="color-hex"><%= allSettings.error_color %></span>
          </div>
        </div>
      </div>
      <div class="settings-actions">
        <button type="submit" class="btn btn-primary"><%= t('settings.saveColors') %></button>
        <button type="button" class="btn btn-secondary" id="reset-colors-btn"><%= t('common.reset') %></button>
      </div>
    </form>
  </div>
  <% } %>

  <!-- App Info -->
  <div class="settings-card card">
    <h2 class="settings-card-title"><%= t('settings.appInfo') %></h2>
    <div class="app-info-grid">
      <div class="app-info-item">
        <span class="app-info-label"><%= t('settings.version') %></span>
        <span class="app-info-value">1.0.1</span>
      </div>
      <div class="app-info-item">
        <span class="app-info-label"><%= t('settings.license') %></span>
        <span class="app-info-value">MIT</span>
      </div>
    </div>
  </div>

  <!-- Logout -->
  <div class="settings-card card">
    <button type="button" id="settings-logout-btn" class="btn btn-danger btn-full"><%= t('settings.logoutBtn') %></button>
  </div>
</div>

<%- include('partials/footer') %>
