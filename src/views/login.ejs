<%- include('partials/header') %>

<div class="auth-container">
  <div class="auth-form">
    <div class="auth-logo">
      <img src="/logo-icon.svg" alt="BugIO">
    </div>
    <h1><%= settings.systemName || 'BugIO' %></h1>
    <p class="auth-subtitle"><%= t('login.subtitle') %></p>

    <form data-form="login">
      <div class="form-group">
        <label for="email"><%= t('login.email') %></label>
        <input type="email" id="email" name="email" required placeholder="<%= t('login.emailPlaceholder') %>">
      </div>

      <div class="form-group">
        <label for="password"><%= t('login.password') %></label>
        <input type="password" id="password" name="password" required placeholder="<%= t('login.passwordPlaceholder') %>">
      </div>

      <button type="submit" class="btn btn-primary" style="width: 100%;"><%= t('login.submit') %></button>
    </form>

    <div class="auth-links">
      <%= t('login.noAccount') %> <a href="/register"><%= t('login.register') %></a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
