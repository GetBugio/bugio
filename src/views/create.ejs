<%- include('partials/header') %>

<div class="page-header">
  <h1><%= t('create.title') %></h1>
</div>

<div class="card">
  <form data-form="create-ticket">
    <div class="form-group">
      <label for="title"><%= t('create.titleLabel') %></label>
      <input type="text" id="title" name="title" required placeholder="<%= t('create.titlePlaceholder') %>">
    </div>

    <div class="form-group">
      <label for="tag"><%= t('create.typeLabel') %></label>
      <select id="tag" name="tag" required>
        <option value="bug"><%= t('create.bugOption') %></option>
        <option value="feature"><%= t('create.featureOption') %></option>
      </select>
    </div>

    <div class="form-group">
      <label for="description"><%= t('create.descriptionLabel') %></label>
      <textarea id="description" name="description" required placeholder="<%= t('create.descriptionPlaceholder') %>"></textarea>
      <div class="form-hint"><%= t('create.descriptionHint') %></div>
    </div>

    <% if (!user) { %>
      <div class="form-group">
        <label for="email"><%= t('create.emailLabel') %></label>
        <input type="email" id="email" name="email" placeholder="<%= t('create.emailPlaceholder') %>">
        <div class="form-hint"><%= t('create.emailHint') %></div>
      </div>
    <% } %>

    <div style="display: flex; gap: 1rem; align-items: center;">
      <button type="submit" class="btn btn-primary"><%= t('create.submit') %></button>
      <a href="/" class="btn btn-secondary"><%= t('common.cancel') %></a>
    </div>
  </form>
</div>

<% if (!user) { %>
  <div class="alert alert-info" style="margin-top: 1rem;">
    <strong><%= t('create.tip') %></strong> <a href="/login"><%= t('create.tipLink') %></a> <%= t('create.tipText') %>
  </div>
<% } %>

<%- include('partials/footer') %>
