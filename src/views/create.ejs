<%- include('partials/header') %>

<div class="page-header">
  <h1>Create New Ticket</h1>
</div>

<div class="card">
  <form data-form="create-ticket">
    <div class="form-group">
      <label for="title">Title *</label>
      <input type="text" id="title" name="title" required placeholder="Brief summary of the issue or request">
    </div>

    <div class="form-group">
      <label for="tag">Type *</label>
      <select id="tag" name="tag" required>
        <option value="bug">Bug - Something isn't working</option>
        <option value="feature">Feature - New functionality request</option>
      </select>
    </div>

    <div class="form-group">
      <label for="description">Description *</label>
      <textarea id="description" name="description" required placeholder="Provide detailed information about the bug or feature request..."></textarea>
      <div class="form-hint">Include steps to reproduce for bugs, or expected behavior for features.</div>
    </div>

    <% if (!user) { %>
      <div class="form-group">
        <label for="email">Your Email (optional)</label>
        <input type="email" id="email" name="email" placeholder="email@example.com">
        <div class="form-hint">Provide your email to receive updates about this ticket. You can also submit anonymously.</div>
      </div>
    <% } %>

    <div style="display: flex; gap: 1rem; align-items: center;">
      <button type="submit" class="btn btn-primary">Create Ticket</button>
      <a href="/" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>

<% if (!user) { %>
  <div class="alert alert-info" style="margin-top: 1rem;">
    <strong>Tip:</strong> <a href="/login">Login</a> to track all your tickets and vote on others!
  </div>
<% } %>

<%- include('partials/footer') %>
