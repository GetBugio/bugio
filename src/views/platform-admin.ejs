<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bugio Platform Admin</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <style>
    :root {
      --pa-bg: #0b0b0d;
      --pa-surface: #111113;
      --pa-border: #1e1e22;
      --pa-text: #e8e8ec;
      --pa-text-muted: #888;
      --pa-accent: #3b82f6;
    }
    *, *::before, *::after { box-sizing: border-box; }
    body { background: var(--pa-bg); color: var(--pa-text); font-family: system-ui, -apple-system, sans-serif; margin: 0; min-height: 100vh; }

    /* Toast */
    #pa-toast { position: fixed; top: 1rem; right: 1rem; z-index: 9999; display: flex; flex-direction: column; gap: 0.5rem; pointer-events: none; max-width: 360px; }
    .pa-toast-item { padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.875rem; font-weight: 500; pointer-events: auto; animation: slideIn 0.2s ease; }
    .pa-toast-ok { background: #16a34a; color: #fff; }
    .pa-toast-err { background: #dc2626; color: #fff; }
    @keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }

    /* Top bar */
    .pa-topbar { position: sticky; top: 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; padding: 0 2rem; height: 56px; background: var(--pa-surface); border-bottom: 1px solid var(--pa-border); }
    .pa-topbar-logo { font-size: 1rem; font-weight: 700; }

    /* Content */
    .pa-content { max-width: 1200px; margin: 0 auto; padding: 2rem; display: flex; flex-direction: column; gap: 2rem; }

    /* Cards */
    .pa-card { background: var(--pa-surface); border: 1px solid var(--pa-border); border-radius: 12px; padding: 1.5rem; }
    .pa-card-title { font-size: 1.1rem; font-weight: 600; margin: 0 0 1.25rem; }

    /* Stats */
    .pa-stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 1rem; }
    .pa-stat { background: var(--pa-surface); border: 1px solid var(--pa-border); border-radius: 10px; padding: 1.25rem; }
    .pa-stat-value { font-size: 2rem; font-weight: 700; color: var(--pa-accent); }
    .pa-stat-label { font-size: 0.8rem; color: var(--pa-text-muted); margin-top: 0.25rem; }

    /* Tables */
    .pa-table-wrap { overflow-x: auto; }
    .pa-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .pa-table th { text-align: left; padding: 0.6rem 0.75rem; background: var(--pa-bg); border-bottom: 1px solid var(--pa-border); color: var(--pa-text-muted); font-weight: 500; white-space: nowrap; }
    .pa-table td { padding: 0.65rem 0.75rem; border-bottom: 1px solid var(--pa-border); vertical-align: middle; }
    .pa-table tr:last-child td { border-bottom: none; }
    .pa-table tr:hover td { background: rgba(255,255,255,0.02); }

    /* Badges */
    .badge { display: inline-flex; align-items: center; padding: 0.2rem 0.55rem; border-radius: 999px; font-size: 0.72rem; font-weight: 600; }
    .badge-trial { background: rgba(234,179,8,0.15); color: #ca8a04; }
    .badge-active { background: rgba(34,197,94,0.15); color: #16a34a; }
    .badge-expired { background: rgba(239,68,68,0.15); color: #dc2626; }
    .badge-cancelled { background: rgba(107,114,128,0.15); color: #6b7280; }

    /* Buttons */
    .pa-btn { display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.4rem 0.85rem; border-radius: 6px; border: none; font-size: 0.82rem; font-weight: 500; cursor: pointer; transition: opacity 0.15s; font-family: inherit; }
    .pa-btn:hover { opacity: 0.8; }
    .pa-btn:disabled { opacity: 0.45; cursor: not-allowed; }
    .pa-btn-primary { background: var(--pa-accent); color: #fff; }
    .pa-btn-danger { background: #dc2626; color: #fff; }
    .pa-btn-ghost { background: transparent; color: var(--pa-text); border: 1px solid var(--pa-border); }
    .pa-btn-sm { padding: 0.28rem 0.55rem; font-size: 0.78rem; }

    /* Forms */
    .pa-form-row { display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: flex-end; }
    .pa-field { display: flex; flex-direction: column; gap: 0.3rem; }
    .pa-label { font-size: 0.8rem; color: var(--pa-text-muted); }
    .pa-input { padding: 0.5rem 0.75rem; border: 1px solid var(--pa-border); border-radius: 8px; background: var(--pa-bg); color: var(--pa-text); font-size: 0.875rem; font-family: inherit; outline: none; transition: border-color 0.15s; }
    .pa-input:focus { border-color: var(--pa-accent); }
    .pa-select { padding: 0.5rem 0.75rem; border: 1px solid var(--pa-border); border-radius: 8px; background: var(--pa-bg); color: var(--pa-text); font-size: 0.875rem; font-family: inherit; cursor: pointer; outline: none; }

    /* Section label */
    .pa-section-label { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: var(--pa-text-muted); margin: 0 0 1rem; }

    /* Diagnose */
    .pa-mono { font-family: 'JetBrains Mono', 'Courier New', monospace; font-size: 0.82rem; background: var(--pa-bg); border: 1px solid var(--pa-border); border-radius: 8px; padding: 1.25rem; white-space: pre-wrap; min-height: 80px; color: var(--pa-text-muted); }

    /* Login */
    .pa-login-wrap { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 1rem; }
    .pa-login-card { background: var(--pa-surface); border: 1px solid var(--pa-border); border-radius: 16px; padding: 2.5rem; width: 100%; max-width: 400px; }
    .pa-login-title { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.35rem; }
    .pa-login-sub { color: var(--pa-text-muted); font-size: 0.875rem; margin-bottom: 2rem; }
    .pa-login-err { background: rgba(239,68,68,0.12); color: #f87171; border: 1px solid rgba(239,68,68,0.3); border-radius: 8px; padding: 0.65rem 1rem; font-size: 0.875rem; margin-bottom: 1rem; display: none; }
  </style>
</head>
<body>

<!-- Toast container -->
<div id="pa-toast"></div>

<% if (page === 'login') { %>
  <div class="pa-login-wrap">
    <div class="pa-login-card">
      <div class="pa-login-title">🐛 Platform Admin</div>
      <div class="pa-login-sub">Bugio Admin Panel</div>
      <div id="login-err" class="pa-login-err"></div>
      <form id="login-form">
        <div class="pa-field" style="margin-bottom:1rem;">
          <label class="pa-label">Admin Token</label>
          <input type="password" id="admin-token" class="pa-input" placeholder="Enter admin token" required autocomplete="current-password">
        </div>
        <button type="submit" id="login-btn" class="pa-btn pa-btn-primary" style="width:100%;justify-content:center;padding:0.65rem;">Login</button>
      </form>
    </div>
  </div>

<% } else { %>

  <header class="pa-topbar">
    <div class="pa-topbar-logo">🐛 Bugio Admin</div>
    <button class="pa-btn pa-btn-ghost" id="logout-btn">Logout</button>
  </header>

  <main class="pa-content">

    <!-- Stats -->
    <div>
      <div class="pa-section-label">Overview</div>
      <div class="pa-stats">
        <div class="pa-stat"><div class="pa-stat-value" id="stat-total">—</div><div class="pa-stat-label">Total Workspaces</div></div>
        <div class="pa-stat"><div class="pa-stat-value" id="stat-trial">—</div><div class="pa-stat-label">Trial</div></div>
        <div class="pa-stat"><div class="pa-stat-value" id="stat-active">—</div><div class="pa-stat-label">Active</div></div>
        <div class="pa-stat"><div class="pa-stat-value" id="stat-expired">—</div><div class="pa-stat-label">Expired</div></div>
        <div class="pa-stat"><div class="pa-stat-value" id="stat-cancelled">—</div><div class="pa-stat-label">Cancelled</div></div>
      </div>
    </div>

    <!-- Provision Tenant -->
    <div class="pa-card">
      <div class="pa-card-title">Provision Tenant</div>
      <div class="pa-form-row">
        <div class="pa-field">
          <label class="pa-label">Tenant Name *</label>
          <input type="text" id="prov-name" class="pa-input" placeholder="e.g. bugio" style="width:180px;">
        </div>
        <div class="pa-field">
          <label class="pa-label">Admin Email (optional)</label>
          <input type="email" id="prov-email" class="pa-input" placeholder="admin@example.com" style="width:220px;">
        </div>
        <div class="pa-field">
          <label class="pa-label">Admin Password (optional)</label>
          <input type="password" id="prov-password" class="pa-input" placeholder="min. 6 chars" style="width:180px;" autocomplete="new-password">
        </div>
        <div class="pa-field">
          <label class="pa-label">Status</label>
          <select id="prov-status" class="pa-select">
            <option value="active">active</option>
            <option value="trial">trial</option>
            <option value="expired">expired</option>
            <option value="cancelled">cancelled</option>
          </select>
        </div>
        <div class="pa-field">
          <label class="pa-label">&nbsp;</label>
          <button type="button" class="pa-btn pa-btn-primary" id="prov-btn">Create Tenant</button>
        </div>
      </div>
    </div>

    <!-- Tenants -->
    <div class="pa-card">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
        <div class="pa-card-title" style="margin:0;">Tenants</div>
        <button type="button" class="pa-btn pa-btn-ghost" id="refresh-tenants-btn">↻ Refresh</button>
      </div>
      <div class="pa-table-wrap">
        <table class="pa-table">
          <thead>
            <tr><th>Name</th><th>Status</th><th>Trial Ends</th><th>Created</th><th>Actions</th></tr>
          </thead>
          <tbody id="tenants-tbody">
            <tr><td colspan="5" style="text-align:center;color:var(--pa-text-muted);padding:2rem;">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Coupons -->
    <div class="pa-card">
      <div class="pa-card-title">Coupons</div>
      <div style="background:var(--pa-bg);border:1px solid var(--pa-border);border-radius:8px;padding:1.25rem;margin-bottom:1.5rem;">
        <div class="pa-section-label" style="margin-bottom:0.75rem;">New Coupon</div>
        <div class="pa-form-row">
          <div class="pa-field">
            <label class="pa-label">Code (auto if empty)</label>
            <input type="text" id="coupon-code" class="pa-input" placeholder="SUMMER25" style="width:150px;">
          </div>
          <div class="pa-field">
            <label class="pa-label">Type</label>
            <select id="coupon-type" class="pa-select">
              <option value="trial_extension">Trial Extension</option>
              <option value="free_access">Free Access</option>
              <option value="discount">Discount (Stripe)</option>
            </select>
          </div>
          <div class="pa-field">
            <label class="pa-label">Value (days)</label>
            <input type="number" id="coupon-value" class="pa-input" placeholder="30" style="width:90px;" min="1">
          </div>
          <div class="pa-field">
            <label class="pa-label">Max Uses</label>
            <input type="number" id="coupon-max-uses" class="pa-input" placeholder="1" style="width:90px;" min="0">
          </div>
          <div class="pa-field">
            <label class="pa-label">Expires (ISO)</label>
            <input type="text" id="coupon-expires" class="pa-input" placeholder="2026-12-31" style="width:150px;">
          </div>
          <div class="pa-field">
            <label class="pa-label">&nbsp;</label>
            <button type="button" class="pa-btn pa-btn-primary" id="create-coupon-btn">Create</button>
          </div>
        </div>
      </div>
      <div class="pa-table-wrap">
        <table class="pa-table">
          <thead>
            <tr><th>Code</th><th>Type</th><th>Value</th><th>Uses</th><th>Expires</th><th></th></tr>
          </thead>
          <tbody id="coupons-tbody">
            <tr><td colspan="6" style="text-align:center;color:var(--pa-text-muted);padding:2rem;">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Diagnose -->
    <div class="pa-card">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
        <div class="pa-card-title" style="margin:0;">Diagnose</div>
        <div style="display:flex;gap:0.5rem;">
          <button type="button" class="pa-btn pa-btn-ghost" id="run-diagnose-btn">↻ Run Diagnose</button>
          <button type="button" class="pa-btn pa-btn-danger" id="run-cleanup-btn">🧹 Cleanup Orphans</button>
        </div>
      </div>
      <div id="diagnose-result" class="pa-mono">Click "Run Diagnose" to inspect the data directory.</div>
    </div>

  </main>

<% } %>

<script>
// ─── Toast ────────────────────────────────────────────────────────────────────
function toast(type, msg) {
  var el = document.createElement('div');
  el.className = 'pa-toast-item ' + (type === 'ok' ? 'pa-toast-ok' : 'pa-toast-err');
  el.textContent = msg;
  document.getElementById('pa-toast').appendChild(el);
  setTimeout(function() { el.remove(); }, 5000);
}

<% if (page === 'login') { %>
// ─── Login ────────────────────────────────────────────────────────────────────
document.getElementById('login-form').addEventListener('submit', function(e) {
  e.preventDefault();
  var token = document.getElementById('admin-token').value;
  var errEl = document.getElementById('login-err');
  var btn = document.getElementById('login-btn');
  btn.disabled = true;
  btn.textContent = 'Logging in...';

  fetch('/admin/api/login', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    credentials: 'include',
    body: JSON.stringify({ token: token })
  })
  .then(function(res) { return res.json(); })
  .then(function(data) {
    if (data.success) {
      // Store session token for Bearer auth in the dashboard
      if (data.sessionToken) {
        sessionStorage.setItem('pa_token', data.sessionToken);
      }
      location.href = location.pathname.replace('/login', '') || '/admin';
    } else {
      errEl.textContent = data.error || 'Invalid token';
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Login';
    }
  })
  .catch(function() {
    errEl.textContent = 'Network error – please try again';
    errEl.style.display = 'block';
    btn.disabled = false;
    btn.textContent = 'Login';
  });
});

<% } else { %>
// ─── Dashboard ────────────────────────────────────────────────────────────────

// API base path
var API = location.pathname.startsWith('/admin') ? '/admin/api' : '/api';

// Auth: use Bearer token if available (set during login), fall back to cookie
function authHeaders(extra) {
  var h = Object.assign({ 'Content-Type': 'application/json' }, extra || {});
  var t = sessionStorage.getItem('pa_token');
  if (t) h['Authorization'] = 'Bearer ' + t;
  return h;
}

function apiFetch(path, opts) {
  var options = Object.assign({ credentials: 'include' }, opts || {});
  options.headers = authHeaders(opts && opts.headers ? opts.headers : {});
  if (options.method && options.method !== 'GET' && !options.body) {
    delete options.headers['Content-Type'];
  }
  return fetch(API + path, options)
    .then(function(res) {
      if (!res.ok && res.status === 401) {
        toast('err', 'Session expired – please log in again');
        setTimeout(function() { location.href = location.pathname.replace(/\/?$/, '/login').replace('/admin/login', '/admin/login'); }, 1500);
        throw new Error('Unauthorized');
      }
      return res.json();
    });
}

// ─── Logout ──────────────────────────────────────────────────────────────────
document.getElementById('logout-btn').addEventListener('click', function() {
  apiFetch('/logout', { method: 'POST' })
    .then(function() {
      sessionStorage.removeItem('pa_token');
      location.href = location.pathname.startsWith('/admin') ? '/admin/login' : '/login';
    })
    .catch(function() {
      sessionStorage.removeItem('pa_token');
      location.reload();
    });
});

// ─── Status badge ────────────────────────────────────────────────────────────
function statusBadge(s) {
  return '<span class="badge badge-' + s + '">' + s + '</span>';
}

// ─── Stats ───────────────────────────────────────────────────────────────────
function loadStats() {
  apiFetch('/stats')
    .then(function(data) {
      if (data.success) {
        var s = data.data;
        document.getElementById('stat-total').textContent = s.total != null ? s.total : '—';
        document.getElementById('stat-trial').textContent = s.trial != null ? s.trial : '—';
        document.getElementById('stat-active').textContent = s.active != null ? s.active : '—';
        document.getElementById('stat-expired').textContent = s.expired != null ? s.expired : '—';
        document.getElementById('stat-cancelled').textContent = s.cancelled != null ? s.cancelled : '—';
      }
    })
    .catch(function() {});
}

// ─── Provision ───────────────────────────────────────────────────────────────
document.getElementById('prov-btn').addEventListener('click', function() {
  var name = document.getElementById('prov-name').value.trim();
  var email = document.getElementById('prov-email').value.trim() || undefined;
  var password = document.getElementById('prov-password').value || undefined;
  var status = document.getElementById('prov-status').value;
  var btn = document.getElementById('prov-btn');
  if (!name) { toast('err', 'Tenant name is required'); return; }
  btn.disabled = true; btn.textContent = 'Creating...';
  apiFetch('/provision', {
    method: 'POST',
    body: JSON.stringify({ name: name, adminEmail: email, adminPassword: password, status: status })
  })
  .then(function(data) {
    if (data.success) {
      toast('ok', 'Tenant "' + data.data.name + '" created → ' + data.data.workspaceUrl);
      document.getElementById('prov-name').value = '';
      document.getElementById('prov-email').value = '';
      document.getElementById('prov-password').value = '';
      loadTenants(); loadStats();
    } else {
      toast('err', data.error || 'Provision failed');
    }
  })
  .catch(function(err) { if (err.message !== 'Unauthorized') toast('err', 'Network error'); })
  .finally(function() { btn.disabled = false; btn.textContent = 'Create Tenant'; });
});

// ─── Tenants ─────────────────────────────────────────────────────────────────
function loadTenants() {
  apiFetch('/tenants')
    .then(function(data) {
      if (!data.success) { toast('err', data.error || 'Failed to load tenants'); return; }
      var tbody = document.getElementById('tenants-tbody');
      if (!data.data.length) {
        tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--pa-text-muted);padding:2rem;">No tenants yet</td></tr>';
        return;
      }
      tbody.innerHTML = data.data.map(function(t) {
        var trialEnds = t.trial_ends_at ? new Date(t.trial_ends_at).toLocaleDateString() : '—';
        var created = new Date(t.created_at).toLocaleDateString();
        return '<tr>' +
          '<td><strong>' + escHtml(t.name) + '</strong></td>' +
          '<td>' + statusBadge(t.status) + '</td>' +
          '<td style="font-size:0.8rem;color:var(--pa-text-muted);">' + trialEnds + '</td>' +
          '<td style="font-size:0.8rem;color:var(--pa-text-muted);">' + created + '</td>' +
          '<td>' +
            '<div style="display:flex;gap:0.4rem;align-items:center;flex-wrap:wrap;">' +
              '<select class="pa-select tenant-status-sel" data-name="' + escHtml(t.name) + '" style="font-size:0.8rem;padding:0.25rem 0.5rem;">' +
                '<option value="trial"' + (t.status === 'trial' ? ' selected' : '') + '>trial</option>' +
                '<option value="active"' + (t.status === 'active' ? ' selected' : '') + '>active</option>' +
                '<option value="expired"' + (t.status === 'expired' ? ' selected' : '') + '>expired</option>' +
                '<option value="cancelled"' + (t.status === 'cancelled' ? ' selected' : '') + '>cancelled</option>' +
              '</select>' +
              '<button type="button" class="pa-btn pa-btn-ghost pa-btn-sm" data-action="save-status" data-name="' + escHtml(t.name) + '">Save</button>' +
              '<button type="button" class="pa-btn pa-btn-ghost pa-btn-sm" data-action="reset-pw" data-name="' + escHtml(t.name) + '">Reset PW</button>' +
              '<button type="button" class="pa-btn pa-btn-danger pa-btn-sm" data-action="delete-tenant" data-name="' + escHtml(t.name) + '">Delete</button>' +
            '</div>' +
          '</td>' +
        '</tr>';
      }).join('');
    })
    .catch(function(err) { if (err.message !== 'Unauthorized') toast('err', 'Error loading tenants'); });
}

document.getElementById('refresh-tenants-btn').addEventListener('click', loadTenants);

function setTenantStatus(name) {
  var sel = document.querySelector('.tenant-status-sel[data-name="' + name + '"]');
  var status = sel ? sel.value : null;
  if (!status) { toast('err', 'Could not read status select'); return; }
  apiFetch('/tenants/' + encodeURIComponent(name), {
    method: 'PATCH',
    body: JSON.stringify({ status: status })
  })
  .then(function(data) {
    if (data.success) { toast('ok', '"' + name + '" → ' + status); loadTenants(); loadStats(); }
    else { toast('err', data.error || 'Update failed'); }
  })
  .catch(function(err) { if (err.message !== 'Unauthorized') toast('err', 'Network error'); });
}

function resetTenantPassword(name) {
  var pw = prompt('Reset admin password for "' + name + '":\n(minimum 6 characters)');
  if (pw === null) return;
  if (pw.length < 6) { toast('err', 'Password too short (min. 6 chars)'); return; }
  apiFetch('/tenants/' + encodeURIComponent(name) + '/reset-password', {
    method: 'POST',
    body: JSON.stringify({ newPassword: pw })
  })
  .then(function(data) {
    if (data.success) { toast('ok', 'Password reset for ' + (data.data && data.data.adminEmail ? data.data.adminEmail : name)); }
    else { toast('err', data.error || 'Reset failed'); }
  })
  .catch(function(err) { if (err.message !== 'Unauthorized') toast('err', 'Network error'); });
}

function deleteTenant(name) {
  if (!confirm('Delete tenant "' + name + '"?\n\nThis cannot be undone.')) return;
  apiFetch('/tenants/' + encodeURIComponent(name), { method: 'DELETE' })
    .then(function(data) {
      if (data.success) { toast('ok', 'Tenant "' + name + '" deleted'); loadTenants(); loadStats(); }
      else { toast('err', data.error || 'Delete failed'); }
    })
    .catch(function(err) { if (err.message !== 'Unauthorized') toast('err', 'Network error'); });
}

// ─── Coupons ─────────────────────────────────────────────────────────────────
function loadCoupons() {
  apiFetch('/coupons')
    .then(function(data) {
      if (!data.success) return;
      var tbody = document.getElementById('coupons-tbody');
      if (!data.data.length) {
        tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:var(--pa-text-muted);padding:2rem;">No coupons yet</td></tr>';
        return;
      }
      tbody.innerHTML = data.data.map(function(c) {
        var exp = c.expires_at ? new Date(c.expires_at).toLocaleDateString() : '—';
        var uses = c.times_used + '/' + (c.max_uses === 0 ? '∞' : c.max_uses);
        return '<tr>' +
          '<td><code style="font-family:monospace;">' + escHtml(c.code) + '</code></td>' +
          '<td style="color:var(--pa-text-muted);font-size:0.85rem;">' + escHtml(c.type) + '</td>' +
          '<td>' + (c.value != null ? c.value : '—') + '</td>' +
          '<td style="color:var(--pa-text-muted);font-size:0.85rem;">' + uses + '</td>' +
          '<td style="font-size:0.8rem;color:var(--pa-text-muted);">' + exp + '</td>' +
          '<td><button type="button" class="pa-btn pa-btn-danger pa-btn-sm" data-action="delete-coupon" data-code="' + escHtml(c.code) + '">Delete</button></td>' +
        '</tr>';
      }).join('');
    })
    .catch(function() {});
}

document.getElementById('create-coupon-btn').addEventListener('click', function() {
  var code = document.getElementById('coupon-code').value.trim() || undefined;
  var type = document.getElementById('coupon-type').value;
  var valEl = document.getElementById('coupon-value').value;
  var maxEl = document.getElementById('coupon-max-uses').value;
  var exp = document.getElementById('coupon-expires').value.trim() || undefined;
  var value = valEl ? parseInt(valEl, 10) : undefined;
  var maxUses = maxEl ? parseInt(maxEl, 10) : undefined;
  apiFetch('/coupons', {
    method: 'POST',
    body: JSON.stringify({ code: code, type: type, value: value, maxUses: maxUses, expiresAt: exp })
  })
  .then(function(data) {
    if (data.success) {
      toast('ok', 'Coupon created: ' + data.data.code);
      document.getElementById('coupon-code').value = '';
      document.getElementById('coupon-value').value = '';
      document.getElementById('coupon-max-uses').value = '';
      document.getElementById('coupon-expires').value = '';
      loadCoupons();
    } else {
      toast('err', data.error || 'Failed to create coupon');
    }
  })
  .catch(function(err) { if (err.message !== 'Unauthorized') toast('err', 'Network error'); });
});

function deleteCoupon(code) {
  if (!confirm('Delete coupon "' + code + '"?')) return;
  apiFetch('/coupons/' + encodeURIComponent(code), { method: 'DELETE' })
    .then(function(data) {
      if (data.success) { toast('ok', 'Coupon "' + code + '" deleted'); loadCoupons(); }
      else { toast('err', data.error || 'Delete failed'); }
    })
    .catch(function(err) { if (err.message !== 'Unauthorized') toast('err', 'Network error'); });
}

// ─── Diagnose ────────────────────────────────────────────────────────────────
document.getElementById('run-diagnose-btn').addEventListener('click', function() {
  var el = document.getElementById('diagnose-result');
  el.textContent = 'Running...';
  apiFetch('/diagnose')
    .then(function(data) { el.textContent = JSON.stringify(data.data, null, 2); })
    .catch(function(err) { if (err.message !== 'Unauthorized') el.textContent = 'Network error'; });
});

document.getElementById('run-cleanup-btn').addEventListener('click', function() {
  if (!confirm('Cleanup orphaned tenants?\n\nRemoves registry entries with no matching data folder.')) return;
  apiFetch('/cleanup', { method: 'POST' })
    .then(function(data) {
      var orphaned = data.data && data.data.orphaned;
      document.getElementById('diagnose-result').textContent = orphaned && orphaned.length
        ? 'Removed orphaned tenants: ' + orphaned.join(', ')
        : 'No orphaned tenants found.';
      loadStats();
    })
    .catch(function(err) {
      if (err.message !== 'Unauthorized') document.getElementById('diagnose-result').textContent = 'Network error';
    });
});

// ─── Event delegation (tenant + coupon action buttons) ───────────────────────
document.addEventListener('click', function(e) {
  var btn = e.target.closest('[data-action]');
  if (!btn) return;
  var action = btn.getAttribute('data-action');
  if (action === 'save-status')   { setTenantStatus(btn.getAttribute('data-name')); }
  if (action === 'reset-pw')      { resetTenantPassword(btn.getAttribute('data-name')); }
  if (action === 'delete-tenant') { deleteTenant(btn.getAttribute('data-name')); }
  if (action === 'delete-coupon') { deleteCoupon(btn.getAttribute('data-code')); }
});

// ─── Helpers ──────────────────────────────────────────────────────────────────
function escHtml(str) {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

// ─── Init ────────────────────────────────────────────────────────────────────
loadStats();
loadTenants();
loadCoupons();

<% } %>
</script>
</body>
</html>
