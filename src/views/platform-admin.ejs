<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bugio Platform Admin</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/landing.css">
  <style>
    .pa-layout { display: flex; min-height: 100vh; }
    .pa-sidebar { width: 220px; background: var(--pa-surface); border-right: 1px solid var(--pa-border); padding: 1.5rem 1rem; display: flex; flex-direction: column; gap: 0.25rem; flex-shrink: 0; }
    .pa-sidebar-logo { font-size: 1.1rem; font-weight: 700; color: var(--pa-text); margin-bottom: 1.5rem; padding: 0 0.5rem; display: flex; align-items: center; gap: 0.5rem; }
    .pa-nav-link { display: flex; align-items: center; gap: 0.5rem; padding: 0.6rem 0.75rem; border-radius: 8px; color: var(--pa-text-muted); text-decoration: none; font-size: 0.9rem; cursor: pointer; border: none; background: none; width: 100%; text-align: left; transition: background 0.15s, color 0.15s; }
    .pa-nav-link:hover, .pa-nav-link.active { background: var(--pa-accent-soft); color: var(--pa-accent); }
    .pa-main { flex: 1; padding: 2rem; overflow: auto; }
    .pa-page { display: none; }
    .pa-page.active { display: block; }
    .pa-stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .pa-stat { background: var(--pa-surface); border: 1px solid var(--pa-border); border-radius: 12px; padding: 1.25rem; }
    .pa-stat-value { font-size: 2rem; font-weight: 700; color: var(--pa-accent); }
    .pa-stat-label { font-size: 0.85rem; color: var(--pa-text-muted); margin-top: 0.25rem; }
    .pa-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .pa-table th { text-align: left; padding: 0.75rem 1rem; background: var(--pa-surface); border-bottom: 1px solid var(--pa-border); color: var(--pa-text-muted); font-weight: 500; }
    .pa-table td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--pa-border); color: var(--pa-text); vertical-align: middle; }
    .pa-table tr:hover td { background: var(--pa-surface); }
    .pa-badge { display: inline-flex; align-items: center; padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; }
    .pa-badge-trial { background: rgba(234,179,8,0.15); color: #ca8a04; }
    .pa-badge-active { background: rgba(34,197,94,0.15); color: #16a34a; }
    .pa-badge-expired { background: rgba(239,68,68,0.15); color: #dc2626; }
    .pa-badge-cancelled { background: rgba(107,114,128,0.15); color: #6b7280; }
    .pa-btn { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.4rem 0.85rem; border-radius: 6px; border: none; font-size: 0.85rem; font-weight: 500; cursor: pointer; transition: opacity 0.15s; }
    .pa-btn:hover { opacity: 0.8; }
    .pa-btn-primary { background: var(--pa-accent); color: #fff; }
    .pa-btn-danger { background: #dc2626; color: #fff; }
    .pa-btn-ghost { background: var(--pa-surface); color: var(--pa-text); border: 1px solid var(--pa-border); }
    .pa-section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
    .pa-section-header h2 { font-size: 1.25rem; font-weight: 600; color: var(--pa-text); }
    .pa-form-row { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1rem; }
    .pa-input { padding: 0.5rem 0.75rem; border: 1px solid var(--pa-border); border-radius: 8px; background: var(--pa-bg); color: var(--pa-text); font-size: 0.9rem; font-family: inherit; outline: none; }
    .pa-input:focus { border-color: var(--pa-accent); }
    .pa-select { padding: 0.5rem 0.75rem; border: 1px solid var(--pa-border); border-radius: 8px; background: var(--pa-bg); color: var(--pa-text); font-size: 0.9rem; font-family: inherit; cursor: pointer; }
    .pa-login-wrap { min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .pa-login-card { background: var(--pa-surface); border: 1px solid var(--pa-border); border-radius: 16px; padding: 2.5rem; width: 100%; max-width: 400px; }
    .pa-login-title { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--pa-text); }
    .pa-login-sub { color: var(--pa-text-muted); font-size: 0.9rem; margin-bottom: 2rem; }
    .pa-error { background: rgba(239,68,68,0.1); color: #dc2626; border: 1px solid rgba(239,68,68,0.3); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.9rem; margin-bottom: 1rem; display: none; }
    .pa-success { background: rgba(34,197,94,0.1); color: #16a34a; border: 1px solid rgba(34,197,94,0.3); border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.9rem; margin-bottom: 1rem; display: none; }

    :root {
      --pa-bg: #0b0b0d;
      --pa-surface: #111113;
      --pa-border: #1e1e22;
      --pa-text: #e8e8ec;
      --pa-text-muted: #888;
      --pa-accent: #3b82f6;
      --pa-accent-soft: rgba(59,130,246,0.12);
    }
  </style>
</head>
<body style="background: var(--pa-bg); color: var(--pa-text); font-family: 'Inter', sans-serif; margin: 0;">

<% if (page === 'login') { %>
  <div class="pa-login-wrap">
    <div class="pa-login-card">
      <div class="pa-login-title">🐛 Platform Admin</div>
      <div class="pa-login-sub">Bugio Admin Panel</div>
      <div id="login-error" class="pa-error"></div>
      <form id="login-form">
        <div style="margin-bottom: 1rem;">
          <label style="display:block;font-size:0.85rem;color:var(--pa-text-muted);margin-bottom:0.35rem;">Admin Token</label>
          <input type="password" id="admin-token" class="pa-input" style="width:100%;box-sizing:border-box;" placeholder="Enter admin token" required>
        </div>
        <button type="submit" class="pa-btn pa-btn-primary" style="width:100%;justify-content:center;padding:0.75rem;">Login</button>
      </form>
    </div>
  </div>
<% } else { %>
  <div class="pa-layout">
    <aside class="pa-sidebar">
      <div class="pa-sidebar-logo">🐛 Admin</div>
      <button class="pa-nav-link active" data-section="dashboard">📊 Dashboard</button>
      <button class="pa-nav-link" data-section="tenants">🏢 Tenants</button>
      <button class="pa-nav-link" data-section="coupons">🎟 Coupons</button>
      <button class="pa-nav-link" data-section="diagnose">🔧 Diagnose</button>
      <div style="flex:1;"></div>
      <button class="pa-nav-link" id="logout-btn">🚪 Logout</button>
    </aside>

    <main class="pa-main">
      <!-- Dashboard -->
      <div class="pa-page active" id="section-dashboard">
        <div class="pa-section-header"><h2>Dashboard</h2></div>
        <div class="pa-stats" id="stats-grid">
          <div class="pa-stat"><div class="pa-stat-value" id="stat-total">-</div><div class="pa-stat-label">Total Workspaces</div></div>
          <div class="pa-stat"><div class="pa-stat-value" id="stat-trial">-</div><div class="pa-stat-label">Trial</div></div>
          <div class="pa-stat"><div class="pa-stat-value" id="stat-active">-</div><div class="pa-stat-label">Active</div></div>
          <div class="pa-stat"><div class="pa-stat-value" id="stat-expired">-</div><div class="pa-stat-label">Expired</div></div>
          <div class="pa-stat"><div class="pa-stat-value" id="stat-cancelled">-</div><div class="pa-stat-label">Cancelled</div></div>
        </div>
      </div>

      <!-- Tenants -->
      <div class="pa-page" id="section-tenants">
        <div class="pa-section-header">
          <h2>Tenants</h2>
          <button class="pa-btn pa-btn-ghost" onclick="loadTenants()">↻ Refresh</button>
        </div>
        <div id="tenants-error" class="pa-error"></div>
        <div style="overflow-x:auto;">
          <table class="pa-table">
            <thead>
              <tr>
                <th>Name</th><th>Status</th><th>Trial ends</th><th>Stripe</th><th>Created</th><th>Actions</th>
              </tr>
            </thead>
            <tbody id="tenants-tbody">
              <tr><td colspan="6" style="text-align:center;color:var(--pa-text-muted);">Loading...</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Coupons -->
      <div class="pa-page" id="section-coupons">
        <div class="pa-section-header"><h2>Coupons</h2></div>
        <div id="coupons-error" class="pa-error"></div>
        <div id="coupons-success" class="pa-success"></div>

        <!-- Create coupon form -->
        <div style="background:var(--pa-surface);border:1px solid var(--pa-border);border-radius:12px;padding:1.5rem;margin-bottom:2rem;">
          <h3 style="margin:0 0 1rem;font-size:1rem;">Create Coupon</h3>
          <div class="pa-form-row">
            <input type="text" id="coupon-code" class="pa-input" placeholder="Code (auto if empty)" style="width:160px;">
            <select id="coupon-type" class="pa-select">
              <option value="trial_extension">Trial Extension</option>
              <option value="free_access">Free Access</option>
              <option value="discount">Discount (Stripe)</option>
            </select>
            <input type="number" id="coupon-value" class="pa-input" placeholder="Value (days)" style="width:120px;">
            <input type="number" id="coupon-max-uses" class="pa-input" placeholder="Max uses (1)" style="width:110px;">
            <input type="text" id="coupon-expires" class="pa-input" placeholder="Expires (ISO date)" style="width:180px;">
            <button class="pa-btn pa-btn-primary" onclick="createCoupon()">Create</button>
          </div>
        </div>

        <table class="pa-table">
          <thead>
            <tr><th>Code</th><th>Type</th><th>Value</th><th>Uses</th><th>Expires</th><th>Actions</th></tr>
          </thead>
          <tbody id="coupons-tbody">
            <tr><td colspan="6" style="text-align:center;color:var(--pa-text-muted);">Loading...</td></tr>
          </tbody>
        </table>
      </div>

      <!-- Diagnose -->
      <div class="pa-page" id="section-diagnose">
        <div class="pa-section-header">
          <h2>Diagnose</h2>
          <div style="display:flex;gap:0.5rem;">
            <button class="pa-btn pa-btn-ghost" onclick="loadDiagnose()">↻ Run Diagnose</button>
            <button class="pa-btn pa-btn-danger" onclick="runCleanup()">🧹 Cleanup Orphans</button>
          </div>
        </div>
        <div id="diagnose-result" style="font-family:'JetBrains Mono',monospace;font-size:0.85rem;background:var(--pa-surface);border:1px solid var(--pa-border);border-radius:12px;padding:1.5rem;white-space:pre-wrap;"></div>
      </div>
    </main>
  </div>
<% } %>

<script>
<% if (page === 'login') { %>
  document.getElementById('login-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const token = document.getElementById('admin-token').value;
    const err = document.getElementById('login-error');
    try {
      const res = await fetch('/api/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token }),
      });
      const data = await res.json();
      if (data.success) {
        location.href = '/';
      } else {
        err.textContent = data.error || 'Invalid token';
        err.style.display = 'block';
      }
    } catch {
      err.textContent = 'Network error';
      err.style.display = 'block';
    }
  });
<% } else { %>
  // Navigation
  document.querySelectorAll('[data-section]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.pa-nav-link').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.pa-page').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('section-' + btn.dataset.section).classList.add('active');
      if (btn.dataset.section === 'tenants') loadTenants();
      if (btn.dataset.section === 'coupons') loadCoupons();
      if (btn.dataset.section === 'diagnose') loadDiagnose();
    });
  });

  document.getElementById('logout-btn').addEventListener('click', async () => {
    await fetch('/api/logout', { method: 'POST' });
    location.reload();
  });

  function statusBadge(s) {
    return `<span class="pa-badge pa-badge-${s}">${s}</span>`;
  }

  // Load stats
  async function loadStats() {
    try {
      const res = await fetch('/api/stats');
      const data = await res.json();
      if (data.success) {
        const s = data.data;
        document.getElementById('stat-total').textContent = s.total;
        document.getElementById('stat-trial').textContent = s.trial;
        document.getElementById('stat-active').textContent = s.active;
        document.getElementById('stat-expired').textContent = s.expired;
        document.getElementById('stat-cancelled').textContent = s.cancelled;
      }
    } catch {}
  }

  // Load tenants
  async function loadTenants() {
    try {
      const res = await fetch('/api/tenants');
      const data = await res.json();
      if (!data.success) return;
      const tbody = document.getElementById('tenants-tbody');
      tbody.innerHTML = data.data.map(t => `
        <tr>
          <td><strong>${t.name}</strong></td>
          <td>${statusBadge(t.status)}</td>
          <td style="font-size:0.8rem;color:var(--pa-text-muted);">${t.trial_ends_at ? new Date(t.trial_ends_at).toLocaleDateString() : '—'}</td>
          <td style="font-size:0.8rem;color:var(--pa-text-muted);">${t.stripe_customer_id ? '✓' : '—'}</td>
          <td style="font-size:0.8rem;color:var(--pa-text-muted);">${new Date(t.created_at).toLocaleDateString()}</td>
          <td>
            <select onchange="setTenantStatus('${t.name}', this.value)" style="font-size:0.8rem;padding:0.25rem 0.5rem;border:1px solid var(--pa-border);border-radius:4px;background:var(--pa-bg);color:var(--pa-text);">
              <option value="" disabled selected>Change status</option>
              <option value="trial">trial</option>
              <option value="active">active</option>
              <option value="expired">expired</option>
              <option value="cancelled">cancelled</option>
            </select>
          </td>
        </tr>
      `).join('') || '<tr><td colspan="6" style="text-align:center;color:var(--pa-text-muted);">No tenants</td></tr>';
    } catch {}
  }

  async function setTenantStatus(name, status) {
    if (!status) return;
    await fetch('/api/tenants/' + name, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status }),
    });
    loadTenants();
    loadStats();
  }

  // Load coupons
  async function loadCoupons() {
    try {
      const res = await fetch('/api/coupons');
      const data = await res.json();
      if (!data.success) return;
      const tbody = document.getElementById('coupons-tbody');
      tbody.innerHTML = data.data.map(c => `
        <tr>
          <td><code style="font-family:'JetBrains Mono',monospace;">${c.code}</code></td>
          <td>${c.type}</td>
          <td>${c.value ?? '—'}</td>
          <td>${c.times_used}/${c.max_uses === 0 ? '∞' : c.max_uses}</td>
          <td style="font-size:0.8rem;color:var(--pa-text-muted);">${c.expires_at ? new Date(c.expires_at).toLocaleDateString() : '—'}</td>
          <td><button class="pa-btn pa-btn-danger" onclick="deleteCoupon('${c.code}')">Delete</button></td>
        </tr>
      `).join('') || '<tr><td colspan="6" style="text-align:center;color:var(--pa-text-muted);">No coupons</td></tr>';
    } catch {}
  }

  async function createCoupon() {
    const code = document.getElementById('coupon-code').value.trim() || undefined;
    const type = document.getElementById('coupon-type').value;
    const value = document.getElementById('coupon-value').value ? parseInt(document.getElementById('coupon-value').value) : undefined;
    const maxUses = document.getElementById('coupon-max-uses').value ? parseInt(document.getElementById('coupon-max-uses').value) : undefined;
    const expiresAt = document.getElementById('coupon-expires').value.trim() || undefined;

    const err = document.getElementById('coupons-error');
    const suc = document.getElementById('coupons-success');

    try {
      const res = await fetch('/api/coupons', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code, type, value, maxUses, expiresAt }),
      });
      const data = await res.json();
      if (data.success) {
        suc.textContent = 'Coupon created: ' + data.data.code;
        suc.style.display = 'block';
        err.style.display = 'none';
        loadCoupons();
      } else {
        err.textContent = data.error;
        err.style.display = 'block';
        suc.style.display = 'none';
      }
    } catch {
      err.textContent = 'Network error';
      err.style.display = 'block';
    }
  }

  async function deleteCoupon(code) {
    if (!confirm('Delete coupon ' + code + '?')) return;
    await fetch('/api/coupons/' + code, { method: 'DELETE' });
    loadCoupons();
  }

  // Diagnose
  async function loadDiagnose() {
    const el = document.getElementById('diagnose-result');
    el.textContent = 'Running...';
    try {
      const res = await fetch('/api/diagnose');
      const data = await res.json();
      el.textContent = JSON.stringify(data.data, null, 2);
    } catch {
      el.textContent = 'Error';
    }
  }

  async function runCleanup() {
    if (!confirm('Cleanup orphaned tenants?')) return;
    try {
      const res = await fetch('/api/cleanup', { method: 'POST' });
      const data = await res.json();
      alert('Cleaned up: ' + (data.data?.orphaned?.join(', ') || 'none'));
      loadDiagnose();
    } catch {}
  }

  // Initial load
  loadStats();
<% } %>
</script>
</body>
</html>
