<%- include('partials/header') %>

<div class="page-header">
  <h1><%= t('tickets.title') %></h1>
  <a href="/create" class="btn btn-primary"><%= t('tickets.newTicket') %></a>
</div>

<% const selectedStatuses = Array.isArray(query.status) ? query.status : (query.status ? [query.status] : []) %>
<div class="filters">
  <form method="get" action="/" id="filter-form">
    <div class="filter-group">
      <label for="tag"><%= t('tickets.type') %></label>
      <select name="tag" id="tag">
        <option value=""><%= t('common.all') %></option>
        <option value="bug" <%= query.tag === 'bug' ? 'selected' : '' %>><%= t('common.bug') %></option>
        <option value="feature" <%= query.tag === 'feature' ? 'selected' : '' %>><%= t('common.feature') %></option>
      </select>
    </div>

    <div class="filter-group">
      <label><%= t('tickets.status') %></label>
      <div class="multi-select" id="status-multiselect">
        <button type="button" class="multi-select-btn" id="status-btn">
          <span id="status-btn-label" data-all="<%= t('common.all') %>"><%
            if (selectedStatuses.length === 0) { %><%= t('common.all') %><%
            } else if (selectedStatuses.length === 1) { %><%= t('status.' + selectedStatuses[0]) %><%
            } else { %><%= selectedStatuses.length %> ausgewählt<%
            }
          %></span>
          <svg class="multi-select-arrow" width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><path d="M2 4l4 4 4-4"/></svg>
        </button>
        <div class="multi-select-dropdown" id="status-dropdown">
          <% const statusOptions = [
            { value: 'open', label: t('status.open') },
            { value: 'in_review', label: t('status.in_review') },
            { value: 'in_progress', label: t('status.in_progress') },
            { value: 'rejected', label: t('status.rejected') },
            { value: 'completed', label: t('status.completed') }
          ] %>
          <% statusOptions.forEach(function(opt) { %>
            <label class="multi-select-option">
              <input type="checkbox" name="status" value="<%= opt.value %>"
                <%= selectedStatuses.includes(opt.value) ? 'checked' : '' %>>
              <span class="status status-<%= opt.value %>"><%= opt.label %></span>
            </label>
          <% }) %>
        </div>
      </div>
    </div>

    <div class="filter-group">
      <label for="sortBy"><%= t('tickets.sort') %></label>
      <select name="sortBy" id="sortBy">
        <option value="createdAt" <%= query.sortBy === 'createdAt' || !query.sortBy ? 'selected' : '' %>><%= t('tickets.newest') %></option>
        <option value="votes" <%= query.sortBy === 'votes' ? 'selected' : '' %>><%= t('tickets.mostVoted') %></option>
        <option value="updatedAt" <%= query.sortBy === 'updatedAt' ? 'selected' : '' %>><%= t('tickets.recentlyUpdated') %></option>
      </select>
    </div>

    <div class="filter-group filter-group-search">
      <input type="text" name="search" placeholder="<%= t('tickets.searchPlaceholder') %>" value="<%= query.search || '' %>">
      <button type="submit" class="btn btn-small btn-secondary"><%= t('common.search') %></button>
    </div>
  </form>
</div>


<div id="ticket-list-container">
  <%- include('partials/ticket-list') %>
</div>

<%- include('partials/footer') %>
