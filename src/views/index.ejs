<%- include('partials/header') %>

<div class="page-header">
  <h1>Tickets</h1>
  <a href="/create" class="btn btn-primary">New Ticket</a>
</div>

<div class="filters">
  <form method="get" action="/" id="filter-form">
    <div class="filter-group">
      <label for="tag">Type:</label>
      <select name="tag" id="tag" onchange="this.form.submit()">
        <option value="">All</option>
        <option value="bug" <%= query.tag === 'bug' ? 'selected' : '' %>>Bug</option>
        <option value="feature" <%= query.tag === 'feature' ? 'selected' : '' %>>Feature</option>
      </select>
    </div>

    <div class="filter-group">
      <label for="status">Status:</label>
      <select name="status" id="status" onchange="this.form.submit()">
        <option value="">All</option>
        <option value="open" <%= query.status === 'open' ? 'selected' : '' %>>Open</option>
        <option value="in_review" <%= query.status === 'in_review' ? 'selected' : '' %>>In Review</option>
        <option value="in_progress" <%= query.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
        <option value="rejected" <%= query.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
        <option value="completed" <%= query.status === 'completed' ? 'selected' : '' %>>Completed</option>
      </select>
    </div>

    <div class="filter-group">
      <label for="sortBy">Sort:</label>
      <select name="sortBy" id="sortBy" onchange="this.form.submit()">
        <option value="createdAt" <%= query.sortBy === 'createdAt' || !query.sortBy ? 'selected' : '' %>>Newest</option>
        <option value="votes" <%= query.sortBy === 'votes' ? 'selected' : '' %>>Most Voted</option>
        <option value="updatedAt" <%= query.sortBy === 'updatedAt' ? 'selected' : '' %>>Recently Updated</option>
      </select>
    </div>

    <div class="filter-group">
      <input type="text" name="search" placeholder="Search..." value="<%= query.search || '' %>">
      <button type="submit" class="btn btn-small btn-secondary">Search</button>
    </div>
  </form>
</div>

<div class="ticket-list">
  <% if (tickets.length === 0) { %>
    <div class="card">
      <p>No tickets found. <a href="/create">Create the first one!</a></p>
    </div>
  <% } else { %>
    <% tickets.forEach(ticket => { %>
      <div class="card ticket-card">
        <div class="ticket-votes">
          <% if (user) { %>
            <button class="vote-btn <%= ticket.hasVoted ? 'voted' : '' %>"
                    onclick="handleVote(<%= ticket.id %>, '<%= ticket.hasVoted ? 'remove' : 'add' %>')"
                    title="<%= ticket.hasVoted ? 'Remove vote' : 'Upvote' %>">
              <%= ticket.hasVoted ? '▲' : '△' %>
            </button>
          <% } else { %>
            <span class="vote-btn" title="Login to vote">△</span>
          <% } %>
          <span class="vote-count"><%= ticket.voteCount %></span>
        </div>

        <div class="ticket-content">
          <div class="ticket-header">
            <a href="/ticket/<%= ticket.id %>" class="ticket-title"><%= ticket.title %></a>
            <span class="tag tag-<%= ticket.tag %>"><%= ticket.tag %></span>
            <span class="status status-<%= ticket.status.replace(' ', '_').toLowerCase() %>"><%= ticket.status.replace('_', ' ') %></span>
          </div>

          <div class="ticket-meta">
            #<%= ticket.id %> opened <%= new Date(ticket.createdAt).toLocaleDateString() %>
            <% if (ticket.creatorEmail) { %>
              by <%= ticket.creatorEmail %>
            <% } %>
            &middot; <%= ticket.commentCount || 0 %> comment<%= (ticket.commentCount || 0) !== 1 ? 's' : '' %>
          </div>

          <% if (ticket.description) { %>
            <div class="ticket-description">
              <%= ticket.description.substring(0, 200) %><%= ticket.description.length > 200 ? '...' : '' %>
            </div>
          <% } %>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>

<% if (pagination && pagination.totalPages > 1) { %>
  <div class="pagination">
    <% if (pagination.page > 1) { %>
      <a href="?page=<%= pagination.page - 1 %>&<%= Object.entries(query).filter(([k]) => k !== 'page').map(([k, v]) => k + '=' + v).join('&') %>">&laquo; Prev</a>
    <% } %>

    <% for (let i = 1; i <= pagination.totalPages; i++) { %>
      <% if (i === pagination.page) { %>
        <span class="active"><%= i %></span>
      <% } else { %>
        <a href="?page=<%= i %>&<%= Object.entries(query).filter(([k]) => k !== 'page').map(([k, v]) => k + '=' + v).join('&') %>"><%= i %></a>
      <% } %>
    <% } %>

    <% if (pagination.page < pagination.totalPages) { %>
      <a href="?page=<%= pagination.page + 1 %>&<%= Object.entries(query).filter(([k]) => k !== 'page').map(([k, v]) => k + '=' + v).join('&') %>">Next &raquo;</a>
    <% } %>
  </div>
<% } %>

<%- include('partials/footer') %>
