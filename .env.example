# ===========================================
# Bugio - Environment Configuration
# ===========================================
# Copy this file to .env and adjust the values

# ===========================================
# Deployment Mode (REQUIRED)
# ===========================================
# Controls how Bugio operates:
#   selfhosted  - Single-user mode. No subdomain routing, no trial system,
#                 no Stripe billing. Use this when running on your own server.
#   cloudhosted - Multi-tenant SaaS mode. Subdomain routing, trial system,
#                 Stripe billing, and tenant registration are enabled.
# Default: selfhosted
MODE=selfhosted

# ===========================================
# Server
# ===========================================
PORT=3000
NODE_ENV=production

# ===========================================
# Authentication (REQUIRED)
# ===========================================
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-super-secret-random-string-here

# ===========================================
# Database
# ===========================================
# Base directory for the database.
# Selfhosted:   DATA_DIR/bugio.db
# Cloudhosted:  DATA_DIR/{tenant}/bugio.db
DATA_DIR=./data

# ===========================================
# Admin Dashboard (optional)
# ===========================================
# Token for the admin dashboard at /admin.
# Without this, admin endpoints return 503.
# Generate with: openssl rand -base64 32
ADMIN_TOKEN=

# Admin email address (selfhosted)
ADMIN_EMAIL=admin@example.com

# ===========================================
# Cloudhosted Only (skip if MODE=selfhosted)
# ===========================================

# Base domain for multi-tenant subdomain routing
# Each tenant is accessible at <tenant>.yourdomain.tld
# BASE_DOMAIN=yourdomain.tld

# Default tenant name (used for localhost / direct IP access)
# DEFAULT_TENANT=default

# Auto-provision new tenants on first access
# ALLOW_AUTO_PROVISION=false

# ===========================================
# Stripe Billing (cloudhosted only)
# ===========================================
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=

# ===========================================
# Email / SMTP (optional)
# ===========================================
# Required for password reset and notifications.
# Without SMTP, email features are disabled.
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587                          # 587=STARTTLS, 465=SSL
# SMTP_SECURE=false                      # true for SSL (port 465)
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@yourdomain.com      # optional, defaults to SMTP_USER
#
# APP_URL=https://yourdomain.com        # used in email links (e.g. ticket links)
