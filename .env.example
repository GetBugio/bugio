# ===========================================
# BUGIO - Environment Configuration
# ===========================================

# ===========================================
# DEPLOYMENT MODE (REQUIRED)
# ===========================================
# selfhosted  → single tenant, no Stripe, no multi-tenancy
# cloudhosted → multi-tenant SaaS with Stripe billing
MODE=selfhosted

# ===========================================
# SERVER
# ===========================================
PORT=3000
NODE_ENV=development

# ===========================================
# AUTHENTICATION (REQUIRED)
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# ===========================================
# DATABASE
# ===========================================
# Selfhosted: path to single SQLite file
DATABASE_PATH=./data/bugio.db

# Cloudhosted: base directory for all tenant DBs (DATA_DIR/{tenant}/bugio.db)
DATA_DIR=./data

# ===========================================
# CLOUDHOSTED ONLY
# ===========================================
BASE_DOMAIN=getbugio.com
DEFAULT_TENANT=default
ALLOW_AUTO_PROVISION=false

# ===========================================
# ADMIN PANEL (cloudhosted) - Token for /admin
# ===========================================
# Generate with: openssl rand -base64 32
ADMIN_TOKEN=change-me-to-random-string

# ===========================================
# STRIPE BILLING (cloudhosted)
# ===========================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ===========================================
# SMTP (optional - for notifications)
# ===========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@getbugio.com

# ===========================================
# LEGACY (selfhosted only)
# ===========================================
ADMIN_EMAIL=admin@example.com
